@model IEnumerable<HocTiengTrung.Models.CauHoiGhepTu>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.CotBenTrai)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.CotBenPhai)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.BaiHoc)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.CotBenTrai)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.CotBenPhai)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.BaiHoc.Id)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
